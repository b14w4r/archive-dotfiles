{
	"nodes":[
		{"id":"legend01","type":"text","text":"Легенда\\nслева — НПА\\nцентр — базовые документы\\nсправа — регламенты и акты\\nснизу — сопутствующие документы","x":-1260,"y":-420,"width":310,"height":140},
		{"id":"npa01","type":"text","text":"НПА база\\n149-ФЗ\\n152-ФЗ","x":-1260,"y":-220,"width":260,"height":90},
		{"id":"npa02","type":"text","text":"ПП РФ №1119\\nуровни защищенности\\nИСПДн","x":-1260,"y":-40,"width":260,"height":100},
		{"id":"npa03","type":"text","text":"Приказ ФСТЭК №21\\nмеры защиты ПДн\\nв ИСПДн","x":-1260,"y":160,"width":260,"height":100},
		{"id":"npa04","type":"text","text":"Опц. отдельные ветки\\nГИС — приказ 17 ФСТЭК\\nКИИ — 187-ФЗ + 239","x":-1260,"y":360,"width":260,"height":110},
		{"id":"doc01","type":"text","text":"1. Реестр ИС/ИСПДн\\nи процессов обработки ПДн","x":-820,"y":-240,"width":290,"height":90},
		{"id":"doc02","type":"text","text":"2. Политика ИБ","x":-820,"y":-90,"width":290,"height":70},
		{"id":"doc03","type":"text","text":"3. Политика обработки ПДн\\n+ политика конфиденциальности","x":-820,"y":40,"width":290,"height":90},
		{"id":"doc04","type":"text","text":"4. Приказ о назначении\\nответственного за ПДн/ИБ","x":-820,"y":190,"width":290,"height":90},
		{"id":"doc05","type":"text","text":"5. Акт определения уровня\\nзащищенности ИСПДн","x":-360,"y":-240,"width":290,"height":90},
		{"id":"doc06","type":"text","text":"6. Модель угроз\\nи нарушителя","x":-360,"y":-90,"width":290,"height":80},
		{"id":"doc07","type":"text","text":"7. Положение о защите ПДн\\nв ИСПДн","x":-360,"y":40,"width":290,"height":90},
		{"id":"doc08","type":"text","text":"Сопутствующие приказы\\nоб утверждении политик,\\nположений, регламентов,\\nмодели угроз","x":-360,"y":220,"width":290,"height":120},
		{"id":"doc09","type":"text","text":"8. Правила доступа\\nматрица ролей\\nучетные записи","x":110,"y":-240,"width":290,"height":100},
		{"id":"doc10","type":"text","text":"9. Регламент инцидентов\\nуведомление РКН\\nвзаимодействие с ГосСОПКА","x":110,"y":-70,"width":290,"height":100},
		{"id":"doc11","type":"text","text":"10. Регламент носителей,\\nмобильных, удаленного\\nи внешних подключений","x":110,"y":100,"width":290,"height":100},
		{"id":"doc12","type":"text","text":"11. Проектная и\\nэксплуатационная документация\\nна СЗИ/систему защиты","x":110,"y":270,"width":290,"height":110},
		{"id":"doc13","type":"text","text":"12. Оценка эффективности\\nмер и периодический контроль","x":580,"y":-240,"width":290,"height":90},
		{"id":"doc14","type":"text","text":"Перечни допущенных лиц,\\nобязательства о неразглашении,\\nлисты ознакомления,\\nобучение сотрудников","x":580,"y":-60,"width":290,"height":120},
		{"id":"doc15","type":"text","text":"Журналы и акты\\nучет носителей, инциденты,\\nизменения конфигурации,\\nрезультаты проверок","x":580,"y":150,"width":290,"height":110},
